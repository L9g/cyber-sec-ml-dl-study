# 论文 PDF 是引用材料、体积大，不入 git（索引见 docs/papers/*Reading_List*.md）
docs/papers/*.pdf

# 原始数据不入 git（工作区数据治理硬约束：仅留 README + checksum）
data/**
!data/.gitkeep
!data/**/README.md

# Python env（env per 项目：pyproject.toml + uv.lock 入 git，.venv 不入）
.venv/
__pycache__/
*.pyc

# 真跑输出（结果落 results/experiments.csv 才入 git；临时 json 不入）
results/*.json
